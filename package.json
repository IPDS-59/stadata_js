{
  "name": "stadata-js",
  "version": "2.0.1",
  "description": "JavaScript/TypeScript SDK for Indonesia's Central Statistics Agency (BPS) API",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist/**/*.js",
    "dist/**/*.mjs",
    "dist/**/*.d.ts",
    "dist/**/*.d.mts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:analyze": "tsup --metafile && npx bundle-size-analyzer dist/metafile-*.json",
    "dev": "tsup --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "ci": "npm run lint && npm run typecheck && npm run test:coverage && npm run build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "bps",
    "stadata",
    "indonesia",
    "statistics",
    "api",
    "sdk",
    "typescript"
  ],
  "author": "Ryan Aidil Pratama",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IPDS-59/stadata_js.git"
  },
  "bugs": {
    "url": "https://github.com/IPDS-59/stadata_js/issues"
  },
  "homepage": "https://github.com/IPDS-59/stadata_js#readme",
  "devDependencies": {
    "@rollup/plugin-terser": "^1.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "ts-jest": "^29.4.9",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitepress": "^1.6.4"
  },
  "dependencies": {
    "neverthrow": "^8.2.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
